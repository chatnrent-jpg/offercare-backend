# VettedMe.ai — infrastructure-only environment (no Manus account required)
# Copy to .env and fill in values. Safe for local dev — all delivery modes stay dry-run.

PROJECT_NAME=VettedMe.ai — ALLSAFE Credential Safety Engine
DEBUG=false

# PostgreSQL (local or docker-compose db service)
DATABASE_URL=postgresql://postgres:offercare_secret@localhost:5432/offercare_db

# Admin UI: http://127.0.0.1:8000/admin
ADMIN_API_KEY=change-me-to-a-long-random-string

# Manus webhook hook (ready before Manus account exists)
MANUS_API_KEY=change-me-manus-webhook-secret
MANUS_WORK_QUEUE_DEFAULT_LIMIT=25
MANUS_STALE_CLEAR_DAYS=30
MANUS_MIN_RERUN_HOURS=24
PUBLIC_BASE_URL=http://127.0.0.1:8000

# VettedMe safety alerts (dry-run until go-live)
VETTED_ALERTS_ENABLED=true
VETTED_ADMIN_ALERT_EMAIL=
VETTED_TAGLINE=AI credential verification — safety before placement

# Keep dry-run until operational go-live
SMS_DRY_RUN=true
EMAIL_DRY_RUN=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Credential verification sources (dry-run until go-live)
MBON_VERIFY_DRY_RUN=true
OIG_SCREEN_DRY_RUN=true
MD_JUDICIARY_DRY_RUN=true

# Background safety scheduler
COMPLIANCE_MONITOR_WORKER_ENABLED=true
COMPLIANCE_ALERT_DAYS=14

# Disable shift/sniper workers during infra-only phase (optional)
SNIPER_CASCADE_WORKER_ENABLED=false
STAFFING_VMS_WORKER_ENABLED=false
STAFFING_JOB_BOARD_WORKER_ENABLED=false
