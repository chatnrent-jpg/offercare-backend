# =============================================================================
# VettedCare.ai — copy to .env and fill in values
#   cp .env.example .env
# Docker: set POSTGRES_PASSWORD here; compose wires DATABASE_URL to the db service.
# Local:  DATABASE_URL must match your PostgreSQL instance (URL-encode @ in passwords as %40).
# Deploy: .\scripts\deploy-local.ps1  (or docker compose up -d --build)
# Live SMS: set PUBLIC_BASE_URL, Twilio creds, SMS_DRY_RUN=false, wire webhook in Twilio Console.
# Checklist: GET /api/deploy/checklist (admin) or Admin → Deploy walkthrough panel.
# =============================================================================

# --- Required ---
PROJECT_NAME=VettedCare.ai — ALLSAFE Credential Safety Engine
DATABASE_URL=postgresql://postgres:offercare_secret@localhost:5432/offercare_db

# --- Docker Compose (optional overrides) ---
POSTGRES_PASSWORD=offercare_secret
POSTGRES_PORT=5432
API_PORT=8000

# --- Admin security (Step 11) — set before exposing /admin publicly ---
ADMIN_API_KEY=change-me-to-a-long-random-string
MANUS_API_KEY=change-me-manus-webhook-secret
MANUS_WORK_QUEUE_DEFAULT_LIMIT=25
MANUS_STALE_CLEAR_DAYS=30
MANUS_MIN_RERUN_HOURS=24
PUBLIC_BASE_URL=http://127.0.0.1:8000
VETTED_ALERTS_ENABLED=true
VETTED_ADMIN_ALERT_EMAIL=you@yourdomain.com
VETTED_TAGLINE=AI credential verification — safety before placement

# --- Clinician portal JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# --- Clinician portal OAuth (Google / Facebook) ---
# Redirect URIs to register with each provider:
#   {PUBLIC_BASE_URL}/api/portal/auth/google/callback
#   {PUBLIC_BASE_URL}/api/portal/auth/facebook/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
PORTAL_OAUTH_REDIRECT_BASE=

# --- Twilio SMS (live: SMS_DRY_RUN=false + credentials below) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_DRY_RUN=true
TWILIO_REPLY_KEYWORD=YES
TWILIO_VALIDATE_SIGNATURES=false
# Public HTTPS base URL for Twilio inbound webhook (no trailing slash)
# Example: https://api.yourdomain.com
PUBLIC_BASE_URL=

# --- Email shift alerts (Step 25 — sent alongside SMS on notify/cascade) ---
EMAIL_ALERTS_ENABLED=true
EMAIL_DRY_RUN=true
EMAIL_FROM=alerts@offercare.ai
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Web Push shift alerts (Step 30 — sent alongside SMS/email on notify/cascade) ---
PUSH_ALERTS_ENABLED=true
PUSH_DRY_RUN=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@offercare.ai

# --- VMS outbound (live: VMS_DRY_RUN=false + submission URL) ---
VMS_SUBMISSION_URL=
VMS_DRY_RUN=true
VMS_SUBMISSION_TIMEOUT_SECONDS=20
VMS_AUTH_HEADER=Authorization
VMS_AUTH_TOKEN=

# --- Shift Sniper Matrix weights ---
SNIPER_WEIGHT_COMPLIANCE=100
SNIPER_WEIGHT_RATE_DELTA=10
SNIPER_WEIGHT_RESPONSE_PROPENSITY=25
SNIPER_WEIGHT_FATIGUE=5
SNIPER_LEARNING_ENABLED=true
SNIPER_FATIGUE_WINDOW_HOURS=24
SNIPER_FATIGUE_PER_SMS=0.25
SNIPER_FATIGUE_MAX=5.0
SNIPER_PROPENSITY_PRIOR=0.5
SNIPER_PROPENSITY_PRIOR_WEIGHT=2.0
SNIPER_CASCADE_ENABLED=true
SNIPER_CASCADE_TIMEOUT_SECONDS=90
SNIPER_CASCADE_MAX_RECIPIENTS=5
SNIPER_CASCADE_WORKER_ENABLED=true
SNIPER_CASCADE_WORKER_INTERVAL_SECONDS=15
OPS_AUDIT_ENABLED=true

# --- Production hardening ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_APPLY_PER_MINUTE=5
RATE_LIMIT_TWILIO_PER_MINUTE=60
RATE_LIMIT_DEFAULT_PER_MINUTE=120
SECURITY_HEADERS_ENABLED=true
LOG_LEVEL=INFO
PLACEMENT_P_MAX=0.95
PLACEMENT_DECAY_LAMBDA=0.35
SHIFT_CALENDAR_DURATION_HOURS=12

# --- Maryland facility scraper ---
MARYLAND_HOSPITALS_API_URL=https://opendata.maryland.gov/resource/c4hm-nhk7.json
PA_HOSPITALS_API_URL=https://mapservices.pasda.psu.edu/server/rest/services/pasda/DepHealth/MapServer/6/query
DE_HOSPITALS_API_URL=https://data.cms.gov/provider-data/api/1/datastore/query/xubh-q36u/0
CMS_HOSPITALS_API_URL=https://data.cms.gov/provider-data/api/1/datastore/query/xubh-q36u/0
CMS_NURSING_HOMES_API_URL=https://data.cms.gov/provider-data/api/1/datastore/query/4pq5-n9py/0
CMS_HOME_HEALTH_API_URL=https://data.cms.gov/provider-data/api/1/datastore/query/6jpm-sxkc/0
NJ_HOSPITALS_API_URL=https://data.cms.gov/provider-data/api/1/datastore/query/xubh-q36u/0
FACILITY_SCRAPE_SOURCE=MD_OPENDATA
SUPPORTED_STATES=MD,VA,DC,PA,DE,NJ

# --- License verification stub ---
LICENSE_VERIFY_DRY_RUN=true

# --- Maryland credentialing & COMAR compliance ---
MBON_VERIFY_DRY_RUN=true
MBON_VERIFY_URL=
MBON_VERIFY_TIMEOUT_SECONDS=20
OIG_SCREEN_DRY_RUN=true
OIG_LEIE_SEARCH_URL=
OIG_SCREEN_TIMEOUT_SECONDS=20
MD_JUDICIARY_DRY_RUN=true
MD_JUDICIARY_SEARCH_URL=
MD_JUDICIARY_TIMEOUT_SECONDS=20
GEO_MATCH_RADIUS_MILES=30
GEO_MATCH_USE_POSTGIS=true

# --- Staffing background scheduler (VMS poll + job board crisis scan) ---
STAFFING_VMS_WORKER_ENABLED=true
STAFFING_VMS_WORKER_INTERVAL_SECONDS=900
STAFFING_JOB_BOARD_WORKER_ENABLED=true
STAFFING_JOB_BOARD_WORKER_INTERVAL_SECONDS=86400

# --- Compliance monitor background worker (document expiration sweeps) ---
COMPLIANCE_MONITOR_WORKER_ENABLED=true
COMPLIANCE_MONITOR_WORKER_INTERVAL_SECONDS=3600

# --- Live scraper adapters (Step 133 — gateway + go-live) ---
# Local mock adapters: http://127.0.0.1:8000/api/adapters with LIVE_SCRAPER_MOCK_ADAPTERS_ENABLED=true
# Production: point LIVE_SCRAPER_GATEWAY_BASE_URL at your adapter service and set MOCK=false
LIVE_SCRAPER_GATEWAY_BASE_URL=http://127.0.0.1:8000/api/adapters
LIVE_SCRAPER_MOCK_ADAPTERS_ENABLED=true

COMPLIANCE_ALERT_DAYS=14
CREDENTIALING_AUTO_SCREEN_ON_APPLY=false
VMS_INGEST_DRY_RUN=true
VMS_INGEST_URL=
VMS_INGEST_TIMEOUT_SECONDS=25
VMS_INGEST_PLAYWRIGHT_ENABLED=false
VMS_INGEST_PORTAL_URL=
VMS_INGEST_PORTAL_USER=
VMS_INGEST_PORTAL_PASSWORD=
VMS_INGEST_PLAYWRIGHT_TIMEOUT_SECONDS=45
VMS_INGEST_PORTAL_USER_SELECTOR=input[name='username']
VMS_INGEST_PORTAL_PASSWORD_SELECTOR=input[name='password']
VMS_INGEST_PORTAL_SUBMIT_SELECTOR=button[type='submit']
VMS_INGEST_PORTAL_SHIFTS_SELECTOR=#vms-open-shifts-json

# --- Job board crisis indicator (Indeed / ZipRecruiter) ---
JOB_BOARD_SCRAPE_DRY_RUN=true
JOB_BOARD_SCRAPE_URL=
JOB_BOARD_SCRAPE_TIMEOUT_SECONDS=25
JOB_BOARD_CRISIS_MIN_DAYS=30

# --- B2B outreach (Apollo / ZoomInfo + LLM email) ---
CONTACT_ENRICH_DRY_RUN=true
APOLLO_SEARCH_URL=
APOLLO_API_KEY=
ZOOMINFO_SEARCH_URL=
ZOOMINFO_API_KEY=
CONTACT_ENRICH_TIMEOUT_SECONDS=20

# --- Clay.com OHCQ citation enrichment (DON + HR Staffing Coordinator) ---
CLAY_TABLE_WEBHOOK_URL=
CLAY_TABLE_ID=
CLAY_TABLE_VIEW_ID=
CLAY_SESSION_COOKIE=
CLAY_FIELD_FACILITY_NAME=
CLAY_FIELD_COUNTY=
CLAY_FIELD_FACILITY_TYPE=
CLAY_FIELD_FLAG_REASON=
CLAY_FIELD_CITATION_SUMMARY=
CLAY_FIELD_MD_LICENSE=
CLAY_FIELD_SEARCH_LOCATION=
CLAY_ENRICHMENT_DRY_RUN=true

# --- HeyReach OHCQ DON outreach (LinkedIn + email sequence) ---
HEYREACH_API_KEY=
HEYREACH_LIST_ID=
HEYREACH_CAMPAIGN_ID=
HEYREACH_SENDER_ACCOUNT_IDS=
HEYREACH_OUTREACH_DRY_RUN=true

# --- Workstream Baltimore CNA job distribution ---
WORKSTREAM_API_BASE=https://public-api.workstream.us
WORKSTREAM_CLIENT_ID=
WORKSTREAM_CLIENT_SECRET=
WORKSTREAM_ACCESS_TOKEN=
WORKSTREAM_WEBHOOK_BEARER_TOKEN=
WORKSTREAM_JOB_DISTRIBUTION_DRY_RUN=true
OUTREACH_EMAIL_ENABLED=true
OUTREACH_EMAIL_DRY_RUN=true
OUTREACH_LLM_DRY_RUN=true
OUTREACH_LLM_URL=
OUTREACH_LLM_API_KEY=
OUTREACH_LLM_MODEL=gpt-4o-mini
OUTREACH_LLM_TIMEOUT_SECONDS=30
OUTREACH_SENDER_NAME=Henry Okojie
OUTREACH_AGENCY_NAME=VettedCare.ai

# --- Stripe instant payout + Tier 1 W-2 tax intercept bridge ---
STRIPE_SECRET_KEY=
STRIPE_INSTANT_PAYOUT_DRY_RUN=true
INSTANT_PAY_WINDOW_MINUTES=30
INSTANT_PAY_WORKER_ENABLED=true
INSTANT_PAY_WORKER_INTERVAL_SECONDS=60
PAYROLL_TAX_INTERCEPT_ENABLED=true
PAYROLL_TAX_PROVIDER=local
INSTANT_PAY_FEDERAL_INCOME_EFFECTIVE_RATE=0.12
INSTANT_PAY_MD_STATE_EFFECTIVE_RATE=0.0575
GUSTO_API_TOKEN=
GUSTO_COMPANY_ID=
GUSTO_API_BASE=https://api.gusto-demo.com
GUSTO_API_VERSION=2024-04-01
CHECKHQ_API_KEY=
CHECKHQ_API_BASE=https://sandbox.checkhq.com
CHECKHQ_COMPANY_ID=
CHECKHQ_DEFAULT_WORKPLACE_ID=
PAYROLL_ONBOARDING_SYNC_ENABLED=true
PAYROLL_ONBOARDING_DRY_RUN=true
PAYROLL_ONBOARDING_TIMEOUT_SECONDS=30

# B2B facility invoicing markup engine (shift completion billing audit)
B2B_INVOICING_ENABLED=true
B2B_INVOICE_MARGIN_PCT=0.40
COMPLIANCE_SENTINEL_ENABLED=true
COMPLIANCE_SENTINEL_HB1106_REQUIRED=true
COMPLIANCE_SENTINEL_MBON_MAX_AGE_HOURS=24

# --- HB 1106 algorithmic bias auditor (Claude 3.5 Sonnet prompt matrix) ---
BIAS_AUDITOR_ENABLED=true
BIAS_AUDITOR_DRY_RUN=true
BIAS_AUDITOR_LLM_MODEL=claude-3-5-sonnet-20241022
BIAS_AUDITOR_ANTHROPIC_API_KEY=
BIAS_AUDITOR_LLM_TIMEOUT_SECONDS=30
BIAS_AUDITOR_LOG_PATH=maryland_hb1106_audit.log

# --- Skyflow PII vault (SSN, DOB, Stripe routing tokens) ---
SKYFLOW_VAULT_ENABLED=true
SKYFLOW_VAULT_DRY_RUN=true
SKYFLOW_VAULT_ID=
SKYFLOW_VAULT_URL=
SKYFLOW_VAULT_TABLE=caregivers
SKYFLOW_BEARER_TOKEN=
SKYFLOW_VAULT_TIMEOUT_SECONDS=30
SKYFLOW_DRY_VAULT_PATH=logs/skyflow_dry_vault.json
